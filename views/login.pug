extends layout.pug
include mixins/alert

block metadata
        title login 
        link(rel="stylesheet" href="/styles/stylelogin.css")
block content 
        .container-login
            .login-box
                .container-form-login

                form(action="/login" method="POST")
                    h1 Iniciar Sesion

                    .input-group-login

                        input(type="text" ,name="username", id="username" placeholder= "Usuario" values= formValues ? formValues.username : '')
                    .input-group-login

                        input(type="password" name="password" id="password"  placeholder= "Contraseña" values= formValues ? formValues.password : '')


                    .remember-forgot-login
                        input(type="checkbox") 
                        label Recordarme 
                        a(href="#") Olvidaste tu contraseña? 
                        .btn-login 
                            button(type="submit") Iniciar Sesion   

                    .register-link-login
                        label No tienes cuenta? 
                        a(href="/register") Registrate! 
                    +alert(alert)

