
extends layout.pug
include mixins/alert

block metadata
        
        link(rel="stylesheet", href="/styles/styleRegister.css")
        title Document
block content 
           
        .register-container 
                .register-box   
                        
                        .register-form 
                                form(action="/signup" method= "POST")
                                        h1 Registrarse 

                                        .input-group-register 
                                                input(type="text" name= "username" id= "username"  placeholder= "Usuario" values= formValues ? formValues.username : '')
                                        .input-group-register 
                                                input(type="email" name="gmail" id="gmail"  placeholder= "Correo electronico" values= formValues ? formValues.gmail  : '')
                                        .input-group-register 
                                                input(type="password" name="password" id= "password"  placeholder= "Contraseña" values= formValues ? formValues.password : '')
                                        .input-group-register 
                                                input(type="password" name="confirm_password" id="confirm_password"  placeholder= "Confirmar Contraseña" values= formValues ? formValues.confirm_password : '')
                                     
                                        
                                                                
                                
                                        .register-btn
                                                button(type="submit") Crear Cuenta



                                        .register-login-link
                                                label Ya tienes cuenta?
                                                a(href= "/login") Iniciar Sesion  
                                                
